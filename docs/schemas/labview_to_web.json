  {
    "type": "alarm_event",
    "desc": "Zdarzenie alarmowe (HI/LO/STB/LATCH). Dashboard loguje alarm i wyświetla powiadomienie.",
    "example": {
      "type": "alarm_event",
      "ts": "2026-03-11T10:00:05.000Z",
      "data": {
        "alarmId": "AL_HI",
        "severity": "danger",
        "sev": "danger",
        "pv1": 210.5,
